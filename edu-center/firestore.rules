rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserCenterId() {
      return isAuthenticated() ? getUserData().centerId : null;
    }
    
    function getUserRole() {
      return isAuthenticated() ? getUserData().role : null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    function isDirector() {
      return isAuthenticated() && getUserRole() == 'director';
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isAdminOrDirector() {
      return isDirector() || isAdmin();
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }
    
    function belongsToCenter(centerId) {
      return isAuthenticated() && getUserCenterId() == centerId;
    }
    
    // ==================== GLOBAL COLLECTIONS ====================
    
    // Centers
    match /centers/{centerId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Users
    match /users/{odamId} {
      allow read: if true;
      allow create: if true;
      allow update: if isSuperAdmin() || isAuthenticated();
      allow delete: if isSuperAdmin() || (isAuthenticated() && isDirector());
    }
    
    // Feedback (global)
    match /feedback/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isAdminOrDirector());
    }
    
    // ==================== CENTER-SCOPED COLLECTIONS ====================
    
    // Center Settings
    match /centers/{centerId}/settings/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Students - faqat director o'chira oladi
    match /centers/{centerId}/students/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Teachers - faqat director o'chira oladi
    match /centers/{centerId}/teachers/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Groups - faqat director o'chira oladi
    match /centers/{centerId}/groups/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Payments - faqat director o'chira oladi
    match /centers/{centerId}/payments/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Monthly Bills (Oylik hisoblar) - qisman to'lov tizimi
    match /centers/{centerId}/monthly_bills/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Attendance
    match /centers/{centerId}/attendance/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Grades
    match /centers/{centerId}/grades/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Messages
    match /centers/{centerId}/messages/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create: if isSuperAdmin() || belongsToCenter(centerId);
      allow update: if isSuperAdmin() || belongsToCenter(centerId); // Barcha a'zolar o'qildi belgilay oladi
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Leads - faqat director o'chira oladi
    match /centers/{centerId}/leads/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isDirector());
    }
    
    // Schedule
    match /centers/{centerId}/schedule/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Teacher Ratings
    match /centers/{centerId}/teacher_ratings/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create: if isSuperAdmin() || belongsToCenter(centerId);
      allow update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Homework (Uy vazifalari)
    match /centers/{centerId}/homework/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Homework Submissions (Topshiriqlar)
    match /centers/{centerId}/homework_submissions/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Chat Messages (Guruh xabarlari)
    match /centers/{centerId}/chat_messages/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create: if isSuperAdmin() || belongsToCenter(centerId);
      allow update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Chat Read Status (O'qilganlik holati)
    match /centers/{centerId}/chat_read_status/{docId} {
      allow read, write: if isSuperAdmin() || belongsToCenter(centerId);
    }
    
    // Quizzes (Online testlar)
    match /centers/{centerId}/quizzes/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Quiz Results (Test natijalari)
    match /centers/{centerId}/quiz_results/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Materials (Video/PDF materiallar)
    match /centers/{centerId}/materials/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Rewards (Sovg'alar)
    match /centers/{centerId}/rewards/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Reward Purchases (Sovg'a sotib olishlar)
    match /centers/{centerId}/reward_purchases/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create: if isSuperAdmin() || belongsToCenter(centerId);
      allow update, delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
    
    // Certificates (Sertifikatlar)
    match /centers/{centerId}/certificates/{docId} {
      allow read: if isSuperAdmin() || belongsToCenter(centerId);
      allow create, update: if isSuperAdmin() || belongsToCenter(centerId);
      allow delete: if isSuperAdmin() || (belongsToCenter(centerId) && isAdminOrDirector());
    }
  }
}
