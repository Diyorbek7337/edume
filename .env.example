VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI savollar generatsiyasi — Firebase Cloud Function URL
# Deploy: cd functions && firebase deploy --only functions
# Keyin Cloud Function URL ni shu yerga qo'ying
VITE_AI_FUNCTION_URL=https://generateaiquestions-HASH-uc.a.run.app

# Sentry error monitoring (https://sentry.io)
# Bo'sh qolsa monitoring o'chirilgan bo'ladi (development)
VITE_SENTRY_DSN=https://your_key@sentry.io/your_project_id
