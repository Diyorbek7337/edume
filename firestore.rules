rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserCenterId() {
      return getUserData().centerId;
    }
    
    function getUserRole() {
      return getUserData().role;
    }
    
    function isDirector() {
      return isAuthenticated() && getUserRole() == 'director';
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isAdminOrDirector() {
      return isDirector() || isAdmin();
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }
    
    function belongsToCenter(centerId) {
      return isAuthenticated() && getUserCenterId() == centerId;
    }
    
    // ==================== GLOBAL COLLECTIONS ====================
    
    // Centers - faqat o'qish uchun (yaratish public API orqali)
    match /centers/{centerId} {
      allow read: if isAuthenticated();
      allow create: if true; // Registration uchun
      allow update, delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Users - global, lekin centerId bilan filtrlangan
    match /users/{odamId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == odamId || 
        getUserCenterId() == resource.data.centerId
      );
      allow create: if true; // Registration uchun
      allow update: if isAuthenticated() && (
        request.auth.uid == odamId || 
        (belongsToCenter(resource.data.centerId) && isAdminOrDirector())
      );
      allow delete: if isAuthenticated() && belongsToCenter(resource.data.centerId) && isDirector();
    }
    
    // ==================== CENTER-SCOPED COLLECTIONS ====================
    
    // Center Settings
    match /centers/{centerId}/settings/{docId} {
      allow read: if belongsToCenter(centerId);
      allow write: if belongsToCenter(centerId) && isAdminOrDirector();
    }
    
    // Students
    match /centers/{centerId}/students/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && isAdminOrDirector();
      allow delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Teachers
    match /centers/{centerId}/teachers/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && isAdminOrDirector();
      allow delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Groups
    match /centers/{centerId}/groups/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && isAdminOrDirector();
      allow delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Payments
    match /centers/{centerId}/payments/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && isAdminOrDirector();
      allow delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Attendance
    match /centers/{centerId}/attendance/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && (isAdminOrDirector() || isTeacher());
      allow delete: if belongsToCenter(centerId) && isAdminOrDirector();
    }
    
    // Grades
    match /centers/{centerId}/grades/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && (isAdminOrDirector() || isTeacher());
      allow delete: if belongsToCenter(centerId) && isAdminOrDirector();
    }
    
    // Messages
    match /centers/{centerId}/messages/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create: if belongsToCenter(centerId);
      allow update, delete: if belongsToCenter(centerId) && isAdminOrDirector();
    }
    
    // Leads
    match /centers/{centerId}/leads/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update: if belongsToCenter(centerId) && isAdminOrDirector();
      allow delete: if belongsToCenter(centerId) && isDirector();
    }
    
    // Schedule
    match /centers/{centerId}/schedule/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create, update, delete: if belongsToCenter(centerId) && isAdminOrDirector();
    }
    
    // Teacher Ratings
    match /centers/{centerId}/teacher_ratings/{docId} {
      allow read: if belongsToCenter(centerId);
      allow create: if belongsToCenter(centerId);
      allow update, delete: if belongsToCenter(centerId) && isAdminOrDirector();
    }
  }
}
